# 数据库连接 (PostgreSQL)
# 从您的数据库服务商获取连接字符串
DATABASE_URL="postgresql://user:password@host:5432/buzhou?sslmode=require"
DATABASE_DIRECT_URL="postgresql://user:password@host:5432/buzhou?sslmode=require"

# Redis 连接 (可选)
# 如果不配置，系统将使用内存缓存
# REDIS_URL="rediss://default:password@xxx.upstash.redis.io:6379"
DISABLE_REDIS="true"

# 应用密钥 (必须更改！使用 openssl rand -base64 32 生成)
NEXTAUTH_SECRET="your-production-secret-key-change-me"

# 内部 API 密钥 (用于服务间认证，必须更改！)
INTERNAL_API_KEY="your-production-internal-api-key"

# 管理员默认密码 (仅用于 seed)
ADMIN_DEFAULT_PASSWORD="change-this-password"

# AI 服务配置 (用于生成 QA 对、关键词、关联文章)
# 使用阿里云 DashScope API (OpenAI 兼容模式)
AI_API_URL="https://coding.dashscope.aliyuncs.com/v1/chat/completions"
AI_API_KEY="your-ai-api-key"
AI_MODEL="qwen3.5-plus"

# 正式环境标识
NODE_ENV="production"