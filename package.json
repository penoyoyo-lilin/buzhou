{
  "name": "buzhou",
  "version": "0.1.0",
  "private": true,
  "scripts": {
  "dev": "npm run dev:sqlite",
    "dev:sqlite": "[ -f .env.local ] && mv .env.local .env.local.bak; cp prisma/schema.sqlite.prisma prisma/schema.prisma && prisma generate && rm -rf .next && next dev",
    "dev:postgres": "[ -f .env.local.bak ] && mv .env.local.bak .env.local; cp prisma/schema.postgres.prisma prisma/schema.prisma && prisma generate && rm -rf .next && next dev",
  "dev:clean": "rm -rf .next && next dev",
  "build": "next build",
  "vercel-build": "cp prisma/schema.postgres.prisma prisma/schema.prisma && prisma generate && next build",
  "start": "next start",
  "lint": "next lint",
  "test": "vitest run",
  "test:watch": "vitest",
  "test:coverage": "vitest run --coverage",
  "test:e2e": "playwright test",
  "test:e2e:ui": "playwright test --ui",
  "db:generate": "prisma generate",
  "db:push": "prisma db push",
  "db:seed": "tsx prisma/seed.ts",
  "db:studio": "prisma studio",
  "db:use:sqlite": "cp prisma/schema.sqlite.prisma prisma/schema.prisma && prisma generate",
  "db:use:postgres": "cp prisma/schema.postgres.prisma prisma/schema.prisma && prisma generate",
  "db:migrate:prod": "prisma migrate deploy"
},
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.36.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.378.0",
    "marked": "^17.0.4",
    "nanoid": "^5.0.7",
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "victory-vendor": "^37.3.6",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "playwright": "^1.58.2",
    "postcss": "^8.4.38",
    "prisma": "^5.15.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  }
}
